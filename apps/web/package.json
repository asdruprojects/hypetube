{
  "name": "@hypetube/web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "build": "pnpm --filter @hypetube/contracts build && tsc -b && vite build",
    "preview": "vite preview --port 5173",
    "preview:railway": "vite preview",
    "lint": "echo 'skip'",
    "check-types": "tsc --noEmit",
    "cy:open": "cypress open --e2e --browser electron",
    "cy:run": "cypress run --e2e --browser electron"
  },
  "dependencies": {
    "@hypetube/contracts": "workspace:*",
    "@hypetube/services": "workspace:*",
    "@hypetube/ui": "workspace:*",
    "@tanstack/react-query": "^5.59.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.451.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.2"
  },
  "devDependencies": {
    "@hypetube/typescript-config": "workspace:*",
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "cypress": "^15.15.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.5.4",
    "vite": "^5.4.8"
  }
}
