{
  "name": "hypetube",
  "private": true,
  "scripts": {
    "postinstall": "pnpm --filter @hypetube/contracts build",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@hypetube/api",
    "build:web": "turbo run build --filter=@hypetube/web",
    "start:web": "pnpm --filter @hypetube/web run preview:railway",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.0",
    "typescript": "5.5.4"
  },
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0"
}
